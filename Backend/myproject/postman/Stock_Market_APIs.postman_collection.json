{
  "info": {
    "_postman_id": "7e80dc6f-9997-4eec-8ef1-2a4ec4f5c144",
    "name": "Stock Market APIs (Current)",
    "description": "Collection for current stock, sector, market overview, and gold-silver endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Sector Stocks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/all-sector-stocks/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "all-sector-stocks",
            ""
          ]
        },
        "description": "Returns merged stock data for all configured sectors."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has data array', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('data');",
              "  pm.expect(jsonData.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
