{
  "info": {
    "_postman_id": "40dc8610-4a8d-4a6e-870f-2fdd90c4d073",
    "name": "Portfolio Stock + Gold Silver APIs",
    "description": "Collection for stock, sector, and gold-silver correlation endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Sector Stocks",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/all-sector-stocks/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "all-sector-stocks",
            ""
          ]
        },
        "description": "Returns merged stock data for all configured sectors."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has data array', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('data');",
              "  pm.expect(jsonData.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Stock Detail By Symbol",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/all-sector-stocks/stock/{{symbol}}/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "all-sector-stocks",
            "stock",
            "{{symbol}}",
            ""
          ]
        },
        "description": "Returns one stock record with symbol and detailed fields."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has symbol field', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('symbol');",
              "});"
            ]
          }
        }
      ]
    },
    {
