          ]
        },
        "description": "Returns stocks for a specific sector."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Gold Silver Correlation (JSON)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/all-sector-stocks/gold-silver/?period={{period}}&interval={{interval}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "all-sector-stocks",
            "gold-silver",
            ""
          ],
          "query": [
            {
              "key": "period",
              "value": "{{period}}"
            },
            {
              "key": "interval",
              "value": "{{interval}}"
            }
          ]
        },
        "description": "Returns gold and silver closes with computed correlation."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has correlation and data', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('correlation');",
              "  pm.expect(jsonData).to.have.property('data');",
              "  pm.expect(jsonData.data).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
