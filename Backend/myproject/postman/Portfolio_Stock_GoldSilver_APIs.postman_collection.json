            },
            {
              "key": "interval",
              "value": "{{interval}}"
            }
          ]
        },
        "description": "Downloads CSV file with date, gold_close, silver_close."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('CSV content-type is returned', function () {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('text/csv');",
